+LEFT JOIN vendeu vd      ON vd.CODUSUR = rd.CODUSUR AND vd.CODCLI = rd.CODCLI
+LEFT JOIN EBD.PCUSUARI u ON u.CODUSUR = rd.CODUSUR
+GROUP BY rd.CODUSUR, u.NOME
+ORDER BY PCT_APROVEITAMENTO DESC NULLS LAST
 ```
 
