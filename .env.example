# ============================================================
# EBD.ia — Variáveis de Ambiente (TEMPLATE)
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o .env (já está no .gitignore).
# ============================================================

# ----- Anthropic (Claude API) -----
ANTHROPIC_API_KEY=sk-ant-PREENCHA-COM-A-CHAVE-REAL
ANTHROPIC_MODEL_DEFAULT=claude-sonnet-4-6
ANTHROPIC_MODEL_PREMIUM=claude-opus-4-7

# ----- Winthor (Oracle) -----
ORACLE_USER=EBD_LEITURA
ORACLE_PASSWORD=<TROCAR_EM_PRODUCAO>
ORACLE_DSN=ssp06odascan.grupoebd.ebdbr.com.br:1521/ebd.grupoebd.ebdbr.com.br
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_QUERY_TIMEOUT_MS=30000
ORACLE_DEFAULT_ROW_LIMIT=10000

# ----- PostgreSQL (sessoes, auditoria) -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ebdia
POSTGRES_USER=ebdia_app
POSTGRES_PASSWORD=PREENCHA-COM-SENHA-FORTE
POSTGRES_SSL=disable

# ----- Redis (fila, cache, idempotencia) -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=PREENCHA-COM-SENHA-FORTE
REDIS_PCLIB_CACHE_TTL_SEC=900

# ----- Gateway FastAPI -----
GATEWAY_PORT=8000
GATEWAY_LOG_LEVEL=INFO
GATEWAY_RATE_LIMIT_PER_MIN=60

# ----- WhatsApp Cloud API (Meta) -----
WHATSAPP_PHONE_NUMBER_ID=PREENCHA
WHATSAPP_BUSINESS_ACCOUNT_ID=PREENCHA
WHATSAPP_ACCESS_TOKEN=PREENCHA
WHATSAPP_VERIFY_TOKEN=PREENCHA-UM-TOKEN-ALEATORIO

# ----- Telegram Bot -----
TELEGRAM_BOT_TOKEN=PREENCHA-COM-TOKEN-DO-BOTFATHER
TELEGRAM_WEBHOOK_SECRET=PREENCHA-UM-TOKEN-ALEATORIO

# ----- Metabase -----
METABASE_DB_TYPE=postgres
METABASE_DB_HOST=postgres
METABASE_DB_PORT=5432
METABASE_DB_NAME=metabase
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=PREENCHA-COM-SENHA-FORTE

# ----- Traefik (TLS automatico via Let's Encrypt) -----
TRAEFIK_ACME_EMAIL=thiago.parreira@ebdgrupo.com.br
DOMAIN_CHAT=chat.ebd.ia.br
DOMAIN_API=api.ebd.ia.br
DOMAIN_BI=bi.ebd.ia.br

# ----- Observabilidade -----
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=PREENCHA-COM-SENHA-FORTE
OTEL_EXPORTER_ENDPOINT=http://otel-collector:4317

# ----- Ambiente -----
ENV=development
TZ=America/Sao_Paulo
LOG_LEVEL=INFO

# MCP Oracle Server
MCP_ORACLE_TOKEN=<TROCAR_EM_PRODUCAO_use_openssl_rand_hex_32>
MCP_ORACLE_HOST=0.0.0.0
MCP_ORACLE_PORT=8989
